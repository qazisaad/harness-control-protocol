{
  "name": "@hcp-runner/runner",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "hcp-runner": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connection": {
      "types": "./dist/connection/index.d.ts",
      "import": "./dist/connection/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./harnesses": {
      "types": "./dist/harnesses/index.d.ts",
      "import": "./dist/harnesses/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@hcp-runner/protocol": "0.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
